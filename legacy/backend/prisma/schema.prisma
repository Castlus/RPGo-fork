// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — RPGo
//
// SETUP SUPABASE REALTIME (faça no SQL Editor do Supabase após o migrate):
//   ALTER TABLE personagens         REPLICA IDENTITY FULL;
//   ALTER TABLE itens               REPLICA IDENTITY FULL;
//   ALTER TABLE acoes               REPLICA IDENTITY FULL;
//   ALTER TABLE mensagens           REPLICA IDENTITY FULL;
//   ALTER TABLE mesas               REPLICA IDENTITY FULL;
//   ALTER TABLE calendarios         REPLICA IDENTITY FULL;
//   ALTER TABLE tipos_clima         REPLICA IDENTITY FULL;
//   ALTER TABLE eventos_calendario  REPLICA IDENTITY FULL;
// E adicione cada tabela na lista de publicações do Realtime no Supabase Dashboard.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Mesa {
  id           String       @id @default(uuid())
  userId       String       @map("user_id") // Dono / Narrador
  nome         String
  codigoAcesso String       @unique @map("codigo_acesso")
  bannerUrl    String?      @map("banner_url")
  personagens  Personagem[]
  calendario   Calendario?

  @@map("mesas")
}

model Personagem {
  id            String  @id @default(uuid())
  userId        String  @map("user_id")
  mesaId        String? @map("mesa_id")
  mesa          Mesa?   @relation(fields: [mesaId], references: [id], onDelete: SetNull)

  nome          String
  fotoUrl       String? @map("foto_url")
  nivel         Int     @default(1)
  hpAtual       Int     @default(0)  @map("hp_atual")
  hpMax         Int     @default(0)  @map("hp_max")
  ppAtual       Int     @default(0)  @map("pp_atual")
  ppMax         Int     @default(0)  @map("pp_max")
  cargaMaxima   Float   @default(20) @map("carga_maxima")
  ultimaRolagem String? @map("ultima_rolagem")

  // Atributos desnormalizados para simplicidade de queries
  forca         Int     @default(0)
  destreza      Int     @default(0)
  constituicao  Int     @default(0)
  sabedoria     Int     @default(0)
  vontade       Int     @default(0)
  presenca      Int     @default(0)

  itens  Item[]
  acoes  Acao[]

  @@map("personagens")
}

model Item {
  id            String     @id @default(uuid())
  personagemId  String     @map("personagem_id")
  personagem    Personagem @relation(fields: [personagemId], references: [id], onDelete: Cascade)

  nome          String
  peso          Float      @default(0)
  tipo          String     @default("comum")
  tags          String?
  descricao     String?
  dano          String?
  modificador   Int        @default(0)
  ca            Int        @default(0)
  penalidadeDes Int        @default(0) @map("penalidade_des")
  equipado      Boolean    @default(false)
  favorito      Boolean    @default(false)

  @@map("itens")
}

model Acao {
  id            String     @id @default(uuid())
  personagemId  String     @map("personagem_id")
  personagem    Personagem @relation(fields: [personagemId], references: [id], onDelete: Cascade)

  nome          String
  descricao     String
  tipo          String
  tag           String?

  @@map("acoes")
}

model Mensagem {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  uid         String
  nome        String
  mensagem    String?
  timestamp   DateTime @default(now())
  tipo        String?  @default("texto")
  total       Int?
  modificador Int?
  detalhes    Json?

  @@index([sessionId, timestamp])
  @@map("mensagens")
}

// Calendário por mesa (1:1). Criado lazy no primeiro GET com template gregoriano default.
// Datas são representadas como Int = "dias absolutos desde o dia 0 do calendário".
// ano/mes/dia/diaSemana/estação são derivados de `config` via engine pura.
model Calendario {
  id            String   @id @default(uuid())
  mesaId        String   @unique @map("mesa_id")
  mesa          Mesa     @relation(fields: [mesaId], references: [id], onDelete: Cascade)

  // Estrutura validada em runtime no backend:
  // { meses: [{nome,dias}], diasSemana: [string], estacoes: [{nome,mesInicio,mesFim}],
  //   cicloLuaDias: number, diaSemanaEpoch: number, anoEpoch: number }
  config        Json

  dataAtualDias Int      @default(0) @map("data_atual_dias")

  tiposClima    TipoClima[]
  eventos       EventoCalendario[]

  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt       @map("atualizado_em")

  @@map("calendarios")
}

model TipoClima {
  id              String     @id @default(uuid())
  calendarioId    String     @map("calendario_id")
  calendario      Calendario @relation(fields: [calendarioId], references: [id], onDelete: Cascade)

  nome            String
  descricao       String?
  icone           String?    // classe FontAwesome ou emoji
  // Pesos por estação. Chave = nome da estação em Calendario.config.estacoes.
  // Peso 0 ou ausente = nunca sorteado naquela estação.
  pesosPorEstacao Json       @map("pesos_por_estacao")

  eventos         EventoCalendario[]

  @@index([calendarioId])
  @@map("tipos_clima")
}

model EventoCalendario {
  id           String     @id @default(uuid())
  calendarioId String     @map("calendario_id")
  calendario   Calendario @relation(fields: [calendarioId], references: [id], onDelete: Cascade)

  dataDias     Int        @map("data_dias")
  tipo         String     // 'climatico' | 'narrativo'
  titulo       String
  descricao    String?

  // Quando true, evento não é enviado pro jogador (mesmo se a data atual já passou).
  // Narrador usa pra reservar surpresas/segredos. Default false pra manter retrocompat.
  oculto       Boolean    @default(false)

  // Só preenchido quando tipo='climatico'. SetNull pra preservar histórico se tipo for deletado.
  tipoClimaId  String?    @map("tipo_clima_id")
  tipoClima    TipoClima? @relation(fields: [tipoClimaId], references: [id], onDelete: SetNull)

  criadoEm     DateTime   @default(now()) @map("criado_em")

  @@index([calendarioId, dataDias])
  @@map("eventos_calendario")
}
